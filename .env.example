# Required: target relay endpoint and key
RELAY_BASE_URL="https://your-relay.example.com/v1"
RELAY_API_KEY="your_relay_api_key"

# Optional: official OpenAI key for cross-check in full probe
OFFICIAL_OPENAI_API_KEY="your_official_openai_api_key"

# Optional: for scripts that fallback to OPENAI_API_KEY
OPENAI_API_KEY="${RELAY_API_KEY}"
